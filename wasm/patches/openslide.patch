diff --git a/src/openslide-vendor-sakura.c b/src/openslide-vendor-sakura.c
--- a/src/openslide-vendor-sakura.c
+++ b/src/openslide-vendor-sakura.c
@@ -501,6 +501,10 @@ static gint compare_downsamples(const void *a, const void *b) {
